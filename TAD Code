        }

        body {
            transition: background-color 2s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif; /* 日本語フォントを優先 */
            color: #ffffff;
            padding: 40px 0;
        }

        .mono { font-family: 'Share Tech Mono', monospace; } /* 数字用 */

        .main-container { display: flex; flex-direction: column; gap: 25px; width: 1100px; }
        .row { display: flex; gap: 25px; align-items: stretch; }

        .panel {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        }

        /* 時計 & 為替 */
        .clock-panel { flex: 2; text-align: center; }
        .clock { font-size: 90px; line-height: 1; font-weight: bold; }
        #secondDisplay { font-size: 45px; opacity: 0.4; margin-left: 10px; }
        #dateDisplay { font-size: 24px; margin-bottom: 10px; letter-spacing: 2px; }

        .fx-panel { flex: 1.5; border-top: 6px solid #fff; }
        .fx-rate-main { font-size: 56px; font-weight: bold; line-height: 1.2; }
        #pctText { font-size: 24px; }

        /* 天気パネル共通 */
        .master-panel { width: 100%; display: flex; flex-direction: column; gap: 20px; box-sizing: border-box; }
        .nat-border { border-left: 8px solid var(--accent-cyan); }
