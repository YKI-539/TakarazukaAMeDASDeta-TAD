<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>TakarazukaAMeDASDeta v1.3.1</title>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-late-night: #050505; --bg-dawn: #1a1a2e; --bg-morning: #16213e;
            --bg-day: #0f3460; --bg-evening: #2d142c; --bg-night: #121212;
            --fx-up: #ff4d4d; --fx-down: #4d94ff;
            --accent-cyan: #00f2ff; --accent-yellow: #ffce54; --accent-pink: #ff4df0;
        }

        body {
            transition: background-color 2s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif; /* 日本語フォントを優先 */
            color: #ffffff;
            padding: 40px 0;
        }

        .mono { font-family: 'Share Tech Mono', monospace; } /* 数字用 */

        .main-container { display: flex; flex-direction: column; gap: 25px; width: 1100px; }
        .row { display: flex; gap: 25px; align-items: stretch; }

        .panel {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 24px;
            padding: 25px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.6);
        }

        /* 時計 & 為替 */
        .clock-panel { flex: 2; text-align: center; }
        .clock { font-size: 90px; line-height: 1; font-weight: bold; }
        #secondDisplay { font-size: 45px; opacity: 0.4; margin-left: 10px; }
        #dateDisplay { font-size: 24px; margin-bottom: 10px; letter-spacing: 2px; }

        .fx-panel { flex: 1.5; border-top: 6px solid #fff; }
        .fx-rate-main { font-size: 56px; font-weight: bold; line-height: 1.2; }
        #pctText { font-size: 24px; }

        /* 天気パネル共通 */
        .master-panel { width: 100%; display: flex; flex-direction: column; gap: 20px; box-sizing: border-box; }
        .nat-border { border-left: 8px solid var(--accent-cyan); }
        .loc-border { border-bottom: 8px solid var(--accent-pink); }

        .label { font-size: 14px; color: rgba(255,255,255,0.5); letter-spacing: 2px; font-weight: bold; }
        .panel-title { font-size: 28px; font-weight: bold; display: flex; align-items: center; gap: 15px; }
        .badge { font-size: 14px; padding: 4px 12px; border-radius: 6px; color: #000; font-weight: bold; }

        /* グリッドレイアウト */
        .info-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; }
        .info-item { background: rgba(255, 255, 255, 0.04); padding: 15px; border-radius: 16px; text-align: center; border: 1px solid rgba(255, 255, 255, 0.1); }
        .info-item .val { font-size: 26px; font-weight: bold; display: block; margin: 5px 0; }
        .info-item .unit { font-size: 12px; opacity: 0.6; }

        /* 予報カード */
        .forecast-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; border-top: 2px solid rgba(255,255,255,0.1); padding-top: 20px; }
        .forecast-card { display: flex; align-items: center; justify-content: space-around; background: rgba(255, 255, 255, 0.03); padding: 20px; border-radius: 20px; }
        .f-icon { font-size: 60px; }
        .f-temp { font-size: 32px; font-weight: bold; }
        .f-details { font-size: 16px; line-height: 1.6; opacity: 0.8; }

        /* 3時間タイムライン */
        .hourly-row { display: grid; grid-template-columns: repeat(8, 1fr); gap: 10px; margin-top: 10px; padding-top: 15px; border-top: 1px dashed rgba(255,255,255,0.1); }
        .hourly-item { text-align: center; font-size: 14px; padding: 10px; background: rgba(255,255,255,0.02); border-radius: 12px; }
        .h-time { color: var(--accent-pink); font-size: 13px; margin-bottom: 5px; font-weight: bold; }
        .h-icon { font-size: 24px; margin: 5px 0; }
        .h-temp { font-weight: bold; font-size: 18px; }
        .h-prob { font-size: 12px; opacity: 0.5; margin-top: 3px; }

        .chart-container { height: 70px; margin-top: 10px; }
        .up { color: var(--fx-up); } .down { color: var(--fx-down); }
        .fade { animation: fadeIn 1s; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="row">
            <div class="panel clock-panel">
                <div id="periodLabel" class="label">読込中...</div>
                <div id="dateDisplay" class="mono">0000.00.00</div>
                <div class="clock mono"><span id="timeDisplay">00:00</span><span id="secondDisplay">00</span></div>
            </div>
            <div class="panel fx-panel" id="fxPanel">
                <div style="display: flex; justify-content: space-between;" class="label"><span>米ドル / 円 (USD/JPY)</span><span id="pctText" class="mono">--%</span></div>
                <div class="fx-rate-main mono" id="rateText">---.--</div>
                <div class="chart-container"><canvas id="fxChart"></canvas></div>
            </div>
        </div>

        <div class="panel master-panel nat-border fade" id="natPanel">
            <div class="panel-title">
                <span class="badge" style="background: var(--accent-yellow);">全国監視</span>
                <span id="natCityName" style="color: var(--accent-cyan);">---</span>
                <span class="label" style="margin-left: auto;">次回の更新まで: <span id="timer" class="mono">10</span>秒</span>
            </div>
            <div class="info-grid">
                <div class="info-item"><span class="label">現在</span><span class="val" id="natWeather">--</span></div>
                <div class="info-item"><span class="label">気温</span><span class="val mono" id="natTemp">--.-</span><span class="unit">°C</span></div>
                <div class="info-item"><span class="label">湿度</span><span class="val mono" id="natHumid">--</span><span class="unit">%</span></div>
                <div class="info-item"><span class="label">気圧</span><span class="val mono" id="natPress">----</span><span class="unit">hPa</span></div>
                <div class="info-item"><span class="label">風速/風向</span><span class="val mono" id="natWind">--.-</span><span class="unit">m/s</span><div class="unit" id="natWindDir">--</div></div>
                <div class="info-item"><span class="label">降水/降雪</span><span class="val mono" id="natPrecip">0.0</span><span class="unit">mm / cm</span></div>
            </div>
            <div class="forecast-row">
                <div class="forecast-card"><div id="natTodayIcon" class="f-icon">--</div><div class="f-main"><div class="label">今日の予報</div><div class="f-temp mono" id="natTodayTemp">--°C</div></div><div class="f-details">最高:<span id="natTodayMax" class="up mono">--</span>° 最低:<span id="natTodayMin" class="down mono">--</span>°<br>降水確率: <span id="natTodayProb" class="mono">--</span>%</div></div>
                <div class="forecast-card"><div id="natTomorrowIcon" class="f-icon">--</div><div class="f-main"><div class="label">明日の予報</div><div class="f-temp mono" id="natTomorrowTemp">--°C</div></div><div class="f-details">最高:<span id="natTomorrowMax" class="up mono">--</span>° 最低:<span id="natTomorrowMin" class="down mono">--</span>°<br>降水確率: <span id="natTomorrowProb" class="mono">--</span>%</div></div>
            </div>
        </div>

        <div class="panel master-panel loc-border">
            <div class="panel-title">
                <span class="badge" style="background: var(--accent-pink);">地域情報</span>
                <span style="color: var(--accent-pink);">兵庫県 宝塚市</span>
            </div>
            <div class="info-grid">
                <div class="info-item"><span class="label">現在</span><span class="val" id="locWeather">--</span></div>
                <div class="info-item"><span class="label">気温</span><span class="val mono" id="locTemp">--.-</span><span class="unit">°C</span></div>
                <div class="info-item"><span class="label">湿度</span><span class="val mono" id="locHumid">--</span><span class="unit">%</span></div>
                <div class="info-item"><span class="label">気圧</span><span class="val mono" id="locPress">----</span><span class="unit">hPa</span></div>
                <div class="info-item"><span class="label">風速/風向</span><span class="val mono" id="locWind">--.-</span><span class="unit">m/s</span><div class="unit" id="locWindDir">--</div></div>
                <div class="info-item"><span class="label">降水/降雪</span><span class="val mono" id="locPrecip">0.0</span><span class="unit">mm / cm</span></div>
            </div>
            <div class="forecast-row">
                <div class="forecast-card"><div id="locTodayIcon" class="f-icon">--</div><div class="f-main"><div class="label">今日の予報</div><div class="f-temp mono" id="locTodayTemp">--°C</div></div><div class="f-details">最高:<span id="locTodayMax" class="up mono">--</span>° 最低:<span id="locTodayMin" class="down mono">--</span>°<br>降水確率: <span id="locTodayProb" class="mono">--</span>%</div></div>
                <div class="forecast-card"><div id="locTomorrowIcon" class="f-icon">--</div><div class="f-main"><div class="label">明日の予報</div><div class="f-temp mono" id="locTomorrowTemp">--°C</div></div><div class="f-details">最高:<span id="locTomorrowMax" class="up mono">--</span>° 最低:<span id="locTomorrowMin" class="down mono">--</span>°<br>降水確率: <span id="locTomorrowProb" class="mono">--</span>%</div></div>
            </div>
            <div class="label" style="text-align: center; margin-top: 10px;">24時間・時系列予報（3時間ごと）</div>
            <div class="hourly-row" id="locHourly"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // --- 47都道府県のデータ ---
        const cities = [
            {name:'北海道',lat:43.06,lon:141.35},{name:'青森県',lat:40.82,lon:140.75},{name:'岩手県',lat:39.70,lon:141.15},{name:'宮城県',lat:38.27,lon:140.87},{name:'秋田県',lat:39.72,lon:140.10},{name:'山形県',lat:38.26,lon:140.34},{name:'福島県',lat:37.75,lon:140.47},{name:'茨城県',lat:36.34,lon:140.45},{name:'栃木県',lat:36.57,lon:139.88},{name:'群馬県',lat:36.39,lon:139.06},{name:'埼玉県',lat:35.86,lon:139.65},{name:'千葉県',lat:35.61,lon:140.12},{name:'東京都',lat:35.69,lon:139.69},{name:'神奈川県',lat:35.45,lon:139.64},{name:'新潟県',lat:37.90,lon:139.02},{name:'富山県',lat:36.70,lon:137.21},{name:'石川県',lat:36.59,lon:136.63},{name:'福井県',lat:36.07,lon:136.22},{name:'山梨県',lat:35.66,lon:138.57},{name:'長野県',lat:36.65,lon:138.18},{name:'岐阜県',lat:35.40,lon:136.72},{name:'静岡県',lat:34.98,lon:138.38},{name:'愛知県',lat:35.18,lon:136.91},{name:'三重県',lat:34.73,lon:136.51},{name:'滋賀県',lat:35.00,lon:135.87},{name:'京都府',lat:35.01,lon:135.76},{name:'大阪府',lat:34.69,lon:135.50},{name:'兵庫県',lat:34.69,lon:135.18},{name:'奈良県',lat:34.69,lon:135.83},{name:'和歌山県',lat:34.23,lon:135.17},{name:'鳥取県',lat:35.50,lon:134.24},{name:'島根県',lat:35.47,lon:133.05},{name:'岡山県',lat:34.66,lon:133.92},{name:'広島県',lat:34.39,lon:132.46},{name:'山口県',lat:34.19,lon:131.47},{name:'徳島県',lat:34.07,lon:134.56},{name:'香川県',lat:34.34,lon:134.04},{name:'愛媛県',lat:33.84,lon:132.77},{name:'高知県',lat:33.56,lon:133.53},{name:'福岡県',lat:33.61,lon:130.42},{name:'佐賀県',lat:33.25,lon:130.30},{name:'長崎県',lat:32.75,lon:129.88},{name:'熊本県',lat:32.79,lon:130.74},{name:'大分県',lat:33.24,lon:131.61},{name:'宮崎県',lat:31.91,lon:131.42},{name:'鹿児島県',lat:31.56,lon:130.56},{name:'沖縄県',lat:26.21,lon:127.68}
        ];
        const locCity = { lat: 34.81, lon: 135.34 };
        let curIdx = 0, countdown = 10, prevClose = 0, fxChart;

        const getIcon = code => { if (code <= 1) return '☀️'; if (code <= 3) return '☁️'; if (code <= 67) return '🌧️'; if (code <= 77) return '❄️'; return '⚡'; };
        const getDir = deg => ['北','北東','東','南東','南','南西','西','北西'][Math.round(deg / 45) % 8];

        async function fetchWeather(lat, lon, prefix) {
            try {
                const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max&hourly=weathercode,temperature_2m,relativehumidity_2m,surface_pressure,precipitation,snowfall,precipitation_probability&timezone=Asia%2FTokyo`);
                const d = await res.json();
                const cur = d.current_weather, h = d.hourly, dy = d.daily;

                document.getElementById(`${prefix}Weather`).textContent = getIcon(cur.weathercode);
                document.getElementById(`${prefix}Temp`).textContent = cur.temperature.toFixed(1);
                document.getElementById(`${prefix}Humid`).textContent = h.relativehumidity_2m[0];
                document.getElementById(`${prefix}Press`).textContent = Math.round(h.surface_pressure[0]);
                document.getElementById(`${prefix}Wind`).textContent = cur.windspeed.toFixed(1);
                document.getElementById(`${prefix}WindDir`).textContent = getDir(cur.winddirection);
                document.getElementById(`${prefix}Precip`).textContent = `${h.precipitation[0].toFixed(1)} / ${h.snowfall[0].toFixed(1)}`;

                ['Today', 'Tomorrow'].forEach((day, i) => {
                    document.getElementById(`${prefix}${day}Icon`).textContent = getIcon(dy.weathercode[i]);
                    document.getElementById(`${prefix}${day}Temp`).textContent = `${Math.round((dy.temperature_2m_max[i]+dy.temperature_2m_min[i])/2)}°C`;
                    document.getElementById(`${prefix}${day}Max`).textContent = Math.round(dy.temperature_2m_max[i]);
                    document.getElementById(`${prefix}${day}Min`).textContent = Math.round(dy.temperature_2m_min[i]);
                    document.getElementById(`${prefix}${day}Prob`).textContent = dy.precipitation_probability_max[i];
                });

                if (prefix === 'loc') {
                    const hourlyCont = document.getElementById('locHourly');
                    hourlyCont.innerHTML = '';
                    for (let i = 0; i < 24; i += 3) {
                        const timeStr = h.time[i].split('T')[1];
                        hourlyCont.innerHTML += `
                            <div class="hourly-item">
                                <div class="h-time">${timeStr}</div>
                                <div class="h-icon">${getIcon(h.weathercode[i])}</div>
                                <div class="h-temp mono">${Math.round(h.temperature_2m[i])}°C</div>
                                <div class="h-prob mono">${h.precipitation_probability[i]}%</div>
                            </div>
                        `;
                    }
                }
            } catch (e) { console.error(e); }
        }

        function rotateNational() {
            const c = cities[curIdx];
            document.getElementById('natCityName').textContent = c.name;
            const p = document.getElementById('natPanel');
            p.classList.remove('fade'); void p.offsetWidth; p.classList.add('fade');
            fetchWeather(c.lat, c.lon, 'nat');
            curIdx = (curIdx + 1) % cities.length; countdown = 10;
        }

        function updateClock() {
            const now = new Date(); const hour = now.getHours();
            const colors = [
                {h:0, c:"var(--bg-late-night)", t:"深夜"}, {h:4, c:"var(--bg-dawn)", t:"明け方"}, 
                {h:7, c:"var(--bg-morning)", t:"午前"}, {h:11, c:"var(--bg-day)", t:"日中"}, 
                {h:16, c:"var(--bg-evening)", t:"夕方"}, {h:19, c:"var(--bg-night)", t:"夜間"}
            ].reverse();
            const config = colors.find(c => hour >= c.h);
            document.body.style.backgroundColor = config.c;
            document.getElementById('periodLabel').textContent = config.t;
            const dayNames = ['日','月','火','水','木','金','土'];
            document.getElementById('dateDisplay').textContent = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')} (${dayNames[now.getDay()]})`;
            document.getElementById('timeDisplay').textContent = now.getHours().toString().padStart(2,'0') + ":" + now.getMinutes().toString().padStart(2,'0');
            document.getElementById('secondDisplay').textContent = now.getSeconds().toString().padStart(2,'0');
        }

        function initFX() {
            const ctx = document.getElementById('fxChart').getContext('2d');
            fxChart = new Chart(ctx, { type: 'line', data: { labels: Array(12).fill(''), datasets: [{ data: [], borderColor: '#fff', borderWidth: 3, pointRadius: 0, fill: true, backgroundColor: 'rgba(255,255,255,0.05)', tension: 0.4 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } } });
        }

        async function updateFX() {
            try {
                const res = await fetch('https://api.frankfurter.app/latest?from=USD&to=JPY');
                const data = await res.json(); const rate = data.rates.JPY;
                if (prevClose === 0) prevClose = rate;
                const pct = ((rate - prevClose) / prevClose * 100).toFixed(2);
                document.getElementById('rateText').textContent = rate.toFixed(2);
                document.getElementById('pctText').textContent = (rate>=prevClose?'+':'') + pct + '%';
                document.getElementById('pctText').className = rate>=prevClose?'up':'down';
                fxChart.data.datasets[0].data.push(rate); if (fxChart.data.datasets[0].data.length > 12) fxChart.data.datasets[0].data.shift();
                fxChart.data.datasets[0].borderColor = rate>=prevClose ? '#ff4d4d' : '#4d94ff'; fxChart.update();
            } catch (e) { console.error(e); }
        }

        setInterval(() => { countdown--; document.getElementById('timer').textContent = countdown; if (countdown<=0) rotateNational(); }, 1000);
        setInterval(updateClock, 1000); setInterval(updateFX, 60000); setInterval(() => fetchWeather(locCity.lat, locCity.lon, 'loc'), 300000);

        updateClock(); initFX(); updateFX(); rotateNational(); fetchWeather(locCity.lat, locCity.lon, 'loc');
    </script>
</body>
</html>
